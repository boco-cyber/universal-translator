{
  "name": "universal-translator",
  "version": "1.0.0",
  "description": "Universal AI Translation App — translate any document with any AI provider",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win portable"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "epub2": "^3.0.2",
    "express": "^4.18.2",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "node-html-parser": "^6.1.12",
    "pdf-parse": "^1.1.1",
    "srt-parser-2": "^1.2.3",
    "tiktoken": "^1.0.15",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.universal-translator.app",
    "productName": "Universal Translator",
    "files": [
      "electron.js",
      "server.js",
      "index.html",
      "providers/**/*",
      "extractors/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "icon.png",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "universal-translator.exe"
    },
    "directories": {
      "output": "dist-electron"
    },
    "asar": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["translation", "ai", "anthropic", "openai", "gemini", "ollama"],
  "license": "MIT"
}
